# Version control
.git
.gitignore

# Dependencies (rebuilt inside Docker)
node_modules
apps/*/node_modules
packages/*/node_modules

# Next.js build output
apps/web/.next
apps/web/out

# Environment files — never copy secrets into the image
.env
.env.*
apps/web/.env
apps/web/.env.*

# Editor / OS noise
.DS_Store
.vscode
.idea
*.log

# Docker files themselves
Dockerfile
docker-compose*.yml
.dockerignore

# Mac app (not part of the web container)
apps/mac
